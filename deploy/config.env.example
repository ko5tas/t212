# Copy to /etc/t212/config.env
# Set permissions: sudo chmod 0600 /etc/t212/config.env
# Set ownership:  sudo chown root:root /etc/t212/config.env

# Trading 212 API credentials (both required)
T212_API_KEY=
T212_API_SECRET=

# Your Signal number in E.164 format (optional — omit to disable notifications)
SIGNAL_NUMBER=+447700000000

# Path to signal-cli binary (default: /usr/local/bin/signal-cli)
# SIGNAL_CLI_PATH=/usr/local/bin/signal-cli

# signal-cli data directory (default: /var/lib/t212/signal-cli)
# SIGNAL_CLI_CONFIG=/var/lib/t212/signal-cli

# Port for web UI (default: 8080)
# T212_PORT=8080
